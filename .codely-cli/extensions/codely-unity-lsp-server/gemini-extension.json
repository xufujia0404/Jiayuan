{
  "name": "codely-unity-lsp-server",
  "version": "0.1.1",
  "lspServers": {
    "csharp": {
      "command": "node",
      "args": [
        "${extensionPath}${/}dist${/}server.js"
      ],
      "extensionToLanguage": {
        ".cs": "csharp",
        ".csx": "csharp"
      },
      "cwd": "${extensionPath}",
      "workspace_required": true,
      "defaultInitializationOptions": {}
    }
  }
}
